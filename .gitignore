.env.*
!.env.example
*.key
**/*.pem
secrets/
secrets.toml
secrets.yaml
secrets.json
*credentials*

# Claude Code (user-scoped local overrides and ephemeral runtime state)
.claude/settings.local.json
.claude/worktrees/
.claude/agent-memory/
evals/.claude/settings.local.json

# Outputs & Results
# Everything in results/ is ignored by default — the directory is a
# scratch area for per-run JSON/JSONL/log outputs. A small allowlist
# of versioned, human-reviewed files is permitted below.
results/*
outputs/
*.log
*.jsonl
# Permit the versioned leaderboard schema + its README; individual
# JSON run artifacts remain ignored.
!results/frontier_benchmark_v1.csv
!results/frontier_benchmark_v1.README.md
!results/judge_agreement_v1.md
!results/.gitkeep

# Local data
data/
!data/.gitkeep

# Large files
*.csv
*.parquet
*.pkl
*.joblib
# Allow the versioned leaderboard schema file; other CSVs stay ignored.
!results/frontier_benchmark_v1.csv

# Temp
tmp/
temp/
scratch/

